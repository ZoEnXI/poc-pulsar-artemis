# Copy to .env and fill in — never commit .env
# Pulsar
PULSAR_IMAGE=apachepulsar/pulsar:3.0.17
# RabbitMQ
RABBITMQ_IMAGE=rabbitmq:4.0.9-management
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
# Artemis
ARTEMIS_IMAGE=apache/activemq-artemis:2.36.0
ARTEMIS_USER=artemis
ARTEMIS_PASSWORD=artemis
# OMB runner JDK
OMB_JDK_IMAGE=eclipse-temurin:17-jdk
# App
APP_JDK_IMAGE=eclipse-temurin:25-jdk
