<?xml version='1.0'?>
<!--
  ActiveMQ Artemis 2.36.0 — broker.xml iso-durabilité disque maximale mono-nœud

  Garanties durabilité :
    persistence-enabled=true       → toutes les files sont durables sur disque
    journal-type=ASYNCIO           → journal AIO (Linux io_uring/libaio) ou NIO (fallback)
    journal-sync-transactional=true    → fsync après chaque transaction committée
    journal-sync-non-transactional=true→ fsync après chaque envoi de message hors transactionnel
    address-full-policy=BLOCK      → le producteur est bloqué (pas de drop silencieux)
                                     quand l'adresse atteint max-size-bytes

  Compatibilité client :
    Le driver OMB utilise artemis-core-client 2.23.1 avec le protocole Core natif.
    Le port 61616 écoute en mode AUTO : Core, OpenWire, AMQP sur la même socket.
-->
<configuration xmlns="urn:activemq"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="urn:activemq /schema/artemis-configuration.xsd">

  <core xmlns="urn:activemq:core">

    <name>artemis-benchmark</name>

    <!-- ── Persistance ─────────────────────────────────────────────────── -->
    <persistence-enabled>true</persistence-enabled>

    <!--
      journal-type : ASYNCIO (Linux libaio/io_uring) garantit un fsync bas-niveau
      via O_DSYNC ou io_uring submit. Sur systèmes sans libaio, bascule sur NIO.
      NIO utilise java.nio.channels.FileChannel.force(true) pour le fsync.
    -->
    <journal-type>ASYNCIO</journal-type>
    <journal-directory>data/journal</journal-directory>
    <bindings-directory>data/bindings</bindings-directory>
    <large-messages-directory>data/large-messages</large-messages-directory>
    <paging-directory>data/paging</paging-directory>

    <!-- fsync à chaque message transactionnel (commit) -->
    <journal-sync-transactional>true</journal-sync-transactional>
    <!-- fsync à chaque message non-transactionnel (send direct) -->
    <journal-sync-non-transactional>true</journal-sync-non-transactional>

    <!-- Taille du fichier journal (1 Mo par défaut, suffisant pour bench) -->
    <journal-file-size>10485760</journal-file-size>

    <!-- ── Réseau ───────────────────────────────────────────────────────── -->
    <acceptors>
      <!--
        AUTO sur 61616 : détecte automatiquement le protocole (Core / OpenWire / AMQP).
        Le driver OMB artemis-core-client 2.23.1 utilise le protocole Core.
      -->
      <acceptor name="netty">tcp://0.0.0.0:61616?protocols=CORE,OPENWIRE,AMQP</acceptor>
      <!-- Console web Hawtio -->
      <acceptor name="http">tcp://0.0.0.0:8161?protocols=HTTP</acceptor>
    </acceptors>

    <!-- ── Sécurité (bench local — désactiver l'auth ne masque pas les perf) -->
    <security-enabled>true</security-enabled>
    <security-settings>
      <security-setting match="#">
        <permission type="createDurableQueue" roles="artemis"/>
        <permission type="deleteDurableQueue" roles="artemis"/>
        <permission type="createNonDurableQueue" roles="artemis"/>
        <permission type="deleteNonDurableQueue" roles="artemis"/>
        <permission type="send" roles="artemis"/>
        <permission type="consume" roles="artemis"/>
        <permission type="manage" roles="artemis"/>
      </security-setting>
    </security-settings>

    <!-- ── Flow control producteur ──────────────────────────────────────── -->
    <!--
      address-full-policy=BLOCK : quand une adresse dépasse max-size-bytes,
      le producteur est BLOQUÉ (send() ne retourne pas) jusqu'à ce que
      les consommateurs rattrapent. Ceci garantit un back-pressure réel,
      pas un drop silencieux (DROP) ou une pagination infinie (PAGE).

      max-size-bytes=-1 désactive la limite de taille (pour ne pas bloquer
      prématurément sur un bench ; ajuster si tests backlog).
    -->
    <address-settings>
      <address-setting match="#">
        <dead-letter-address>DLQ</dead-letter-address>
        <expiry-address>ExpiryQueue</expiry-address>
        <redelivery-delay>0</redelivery-delay>
        <max-size-bytes>-1</max-size-bytes>
        <address-full-policy>BLOCK</address-full-policy>
        <message-counter-history-day-limit>10</message-counter-history-day-limit>
        <auto-create-queues>true</auto-create-queues>
        <auto-create-addresses>true</auto-create-addresses>
        <!-- Files durables par défaut -->
        <default-queue-routing-type>MULTICAST</default-queue-routing-type>
      </address-setting>
    </address-settings>

    <!-- ── Files système ──────────────────────────────────────────────── -->
    <queues>
      <queue name="DLQ">
        <address>DLQ</address>
        <durable>true</durable>
      </queue>
      <queue name="ExpiryQueue">
        <address>ExpiryQueue</address>
        <durable>true</durable>
      </queue>
    </queues>

  </core>
</configuration>
