%% RabbitMQ advanced.config
%% Force la persistance Raft (quorum queues) avec fsync explicite.
%% Les quorum queues utilisent Ra (Raft) dont le journal est fsynced par défaut.
[
  {ra, [
    %% Chaque entrée Raft est fsync'd avant d'acquitter — garantie durabilité.
    {wal_sync_method, sync}
  ]}
].
